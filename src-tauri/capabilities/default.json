{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-exists",
    "fs:allow-read-dir",
    "fs:allow-write-file",
    "fs:allow-stat",
    "fs:allow-remove",
    "core:window:allow-start-dragging",
    "core:window:allow-set-fullscreen",
    "core:window:allow-is-fullscreen",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "**" }]
    },
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-watch",
    "fs:allow-unwatch",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "binaries/songrec", "sidecar": true }]
    }
  ]
}
